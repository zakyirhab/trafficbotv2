# --- Veneno Traffic Bot v2.1.0 ---
# Use this as a template for your .env file

# [App settings]
NODE_ENV=production
LOG_LEVEL=info

# [Execution Roles]
# Options: producer, worker, both
BOT_ROLE=both
# Redis URL for BullMQ (required for distributed scaling)
REDIS_URL=redis://127.0.0.1:6379

# [Traffic Config]
DEFAULT_URL=https://example.com
MAX_SESSIONS=1
# Persingkat durasi tinggal (10-15 detik sudah cukup buat bikin load server numpuk)
TARGET_DURATION_MS=15000
# Tambahin timeout biar dia sabar nunggu web kebuka 
PUPPETEER_TIMEOUT=15000
SESSION_TIME=3 # Minutes (integer) or 'random' (60-300s)

# [Stealth & Behavior]
HEADLESS=false
HUMAN_BEHAVIOR=true
BEHAVIOR_INTENSITY=high # low, medium, high

# [Advanced Customization]
ORGANIC_SEARCH=TRUE
# Comma-separated list of keywords
SEARCH_KEYWORDS=QR Suparma Tbk, Qr Suparma Blog,Qr Suparma Tissue Blog  
# Comma-separated list of custom referrers
REFERRER_POOL=
# Automatically match browser geolocation to proxy IP
MATCH_GEOLOCATION=false

# [Browser Seeding]
PERSISTENT_SESSIONS=false
SESSIONS_DATA_DIR=./sessions

# [Traffic Mode]
TRAFFIC_MODE=direct # Options: seo, direct

# [Proxy settings]
MANUAL_PROXIES= 
PROXY_URL=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
